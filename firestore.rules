rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /siteContent/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /creators/{creatorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
